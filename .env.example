PORT=3000

# Home Assistant base URL + long-lived access token (Profile → Security → Long-lived tokens)
HA_URL=http://homeassistant.local:8123
HA_TOKEN=your_long_lived_access_token

# SQLite path the shelf-logger writes + the web server reads.
# In Docker this is /app/data/shelf-events.db; locally default is ./data/shelf-events.db.
SHELF_EVENTS_DB=./data/shelf-events.db

# Web poll interval — how often the server pulls fresh state from HA (ms).
POLL_INTERVAL_MS=30000

# Logger poll interval — how often the logger writes a snapshot row (ms).
# 300000 = 5 min. Keep this larger than POLL_INTERVAL_MS.
LOGGER_POLL_INTERVAL_MS=300000
